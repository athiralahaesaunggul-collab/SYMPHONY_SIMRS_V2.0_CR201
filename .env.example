# ─── AI Studio Config ─────────────────────────────────────────────────────────
# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
APP_URL="MY_APP_URL"

# ─── MySQL Database (Clever Cloud) ────────────────────────────────────────────
# Isi nilai-nilai ini dari Clever Cloud Dashboard > Add-ons > MySQL > Environment variables
# WAJIB diset di Vercel Dashboard > Settings > Environment Variables untuk produksi.
DB_HOST=bxxxxxxxxxxxxxx-mysql.services.clever-cloud.com
DB_USER=uxxxxxxxxxxxxxx
DB_PASSWORD=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
DB_NAME=bxxxxxxxxxxxxxx
DB_PORT=3306
