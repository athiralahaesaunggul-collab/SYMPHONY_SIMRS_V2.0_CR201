rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /patients/{patientId} {
      allow read, write: if true;
    }
    match /soaps/{soapId} {
      allow read, write: if true;
    }
    match /kodings/{kodingId} {
      allow read, write: if true;
    }
    match /berkas/{berkasId} {
      allow read, write: if true;
    }
    match /audit_logs/{logId} {
      allow read, write: if true;
    }
  }
}
